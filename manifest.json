// ORDER TICKET
// ══════════════════════════════════════════
function populateExp(){
  const sel=document.getElementById('ot-exp');sel.innerHTML='';
  const et=new Date(new Date().toLocaleString('en-US',{timeZone:'America/New_York'}));
  for(let i=0;i<8;i++){
    const d=new Date(et);d.setDate(d.getDate()+i+1);
    if(d.getDay()===0)d.setDate(d.getDate()+1);if(d.getDay()===6)d.setDate(d.getDate()+2);
    const lbl=d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'2-digit'});
    const opt=document.createElement('option');opt.value=d.toISOString().split('T')[0];
    opt.textContent=lbl+(i===0?' (1DTE)':'');sel.appendChild(opt);
  }
}

function onTick(){
  const action=document.getElementById('ot-action').value,qty=parseInt(document.getElementById('ot-qty').value)||0;
  const strike=parseFloat(document.getElementById('ot-strike').value)||0,pt=document.getElementById('ot-pt').value;
  const lim=parseFloat(document.getElementById('ot-lim').value)||0,isSell=action==='sell_open';
  const btn=document.getElementById('place-btn');
  btn.className='place-btn '+(isSell?'btn-sell':'btn-buy');
  btn.textContent=isSell?`Sell to Open — ${qty} Contract${qty!==1?'s':''}`:`Buy to Close — ${qty} Contract${qty!==1?'s':''}`;
  btn.disabled=!(strike&&qty);
  const estEl=document.getElementById('est-row');
  if(strike&&qty&&OQ.bid){
    const price=pt==='market'?(isSell?OQ.bid:OQ.ask):pt==='mid'?(OQ.bid+OQ.ask)/2:lim;
    if(price>0){const total=Math.round(price*100*qty*100)/100;estEl.innerHTML=isSell?`Est. credit: <span>+$${total.toLocaleString()}</span> · $${Math.round(price*100)}/contract`:`Est. debit: <span>-$${total.toLocaleString()}</span>`;}
    else estEl.textContent='Enter limit price';
  } else estEl.textContent='Enter strike and quantity above';
}

function onPT(){
  const pt=document.getElementById('ot-pt').value;
  document.getElementById('ot-lim-f').style.display=pt==='market'?'none':'';
  if(pt==='mid'&&OQ.bid)document.getElementById('ot-lim').value=((OQ.bid+OQ.ask)/2).toFixed(2);
  onTick();
}

function renderSug(){
  const el=document.getElementById('sug-banner'),body=document.getElementById('sug-body');
  if(!algoSig||!LD.qqq){el.style.display='none';return;}
  el.style.display='block';
  if(algoSig.action==='skip'){body.innerHTML='<span style="color:var(--rt);font-weight:800">Skip today.</span> Red-light conditions — no trade recommended.';}
  else if(algoSig.action==='sell_put'){body.innerHTML=`<strong>Sell $${algoSig.strike} Put</strong> · ${getNextExp()} (1DTE) · Target ${algoSig.premRange} · ${algoSig.contracts} contracts<br>Stop: 2× premium · Target exit: 15% of premium`;}
}

function applyAlgo(){
  if(!algoSig||algoSig.action==='skip'){toast('No trade recommended');return;}
  document.getElementById('ot-action').value='sell_open';
  document.getElementById('ot-strike').value=algoSig.strike;
  document.getElementById('ot-qty').value=algoSig.contracts;
  document.getElementById('ot-type').value='put';
  document.getElementById('ot-exp').selectedIndex=0;
  simOQ();onTick();toast('Applied ✓');
}

function confirmOrd(){
  const action=document.getElementById('ot-action').value,qty=parseInt(document.getElementById('ot-qty').value)||0;
  const strike=parseFloat(document.getElementById('ot-strike').value)||0,type=document.getElementById('ot-type').value;
  const expSel=document.getElementById('ot-exp'),expVal=expSel.value,expLbl=expSel.options[expSel.selectedIndex]?.text||'';
  const pt=document.getElementById('ot-pt').value,lim=parseFloat(document.getElementById('ot-lim').value)||0;
  const durSel=document.getElementById('ot-dur'),durLbl=durSel.options[durSel.selectedIndex].text;
  if(!strike||!qty){toast('Enter strike and quantity');return;}
  const isSell=action==='sell_open';
  const ep=pt==='market'?(isSell?OQ.bid||.5:OQ.ask||.5):pt==='mid'?((OQ.bid+OQ.ask)/2)||lim:lim;
  if(!ep){toast('Enter limit price');return;}
  const total=Math.round(ep*100*qty*100)/100;
  const sym=`QQQ ${expLbl.replace(' (1DTE)','')} $${strike} ${type.charAt(0).toUpperCase()+type.slice(1)}`;
  pendingOrder={action,qty,strike,type,expVal,expLbl,pt,ep,total,durLbl,sym,isSell};
  document.getElementById('conf-title').textContent=isSell?'Confirm: Sell to Open':'Confirm: Buy to Close';
  document.getElementById('conf-sub').textContent=isSell?'You will collect premium and accept assignment risk.':'You will close your short put position.';
  document.getElementById('conf-detail').innerHTML=`
    <div class="row"><span class="rl">Symbol</span><span class="rv" style="font-size:11px">${sym}</span></div>
    <div class="row"><span class="rl">Action</span><span class="rv">${isSell?'Sell to Open':'Buy to Close'}</span></div>
    <div class="row"><span class="rl">Quantity</span><span class="rv">${qty} contracts</span></div>
    <div class="row"><span class="rl">Exec price</span><span class="rv">$${ep.toFixed(2)}/sh</span></div>
    <div class="row"><span class="rl">${isSell?'Est. credit':'Est. debit'}</span><span class="rv ${isSell?'green':'red'}">${isSell?'+':'-'}$${total.toLocaleString()}</span></div>
    <div class="row"><span class="rl">Duration</span><span class="rv">${durLbl}</span></div>`;
  const cb=document.getElementById('conf-btn');
  cb.className='btn-cf '+(isSell?'btn-cf-sell':'btn-cf-buy');
  cb.textContent=isSell?'Place Sell Order':'Place Buy Order';
  document.getElementById('conf-overlay').classList.add('open');
}

function placeOrder(){
  if(!pendingOrder)return;
  const now=new Date();
  const execTime=now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  if(pendingOrder.isSell){
    const pos={id:Date.now(),symbol:pendingOrder.sym,strike:pendingOrder.strike,type:pendingOrder.type,qty:pendingOrder.qty,execPrice:pendingOrder.ep,expVal:pendingOrder.expVal,expLbl:pendingOrder.expLbl,openedAt:now.toISOString(),execTime,status:'open',tradeType:'sto',total:pendingOrder.total};
    openPos.push(pos);trades.unshift({...pos});
  } else {
    const mi=openPos.findIndex(p=>p.strike===pendingOrder.strike);
    const match=mi>=0?openPos[mi]:null;
    const gain=match?Math.round((match.execPrice-pendingOrder.ep)*100*pendingOrder.qty*100)/100:null;
    const ct={id:Date.now(),symbol:pendingOrder.sym,strike:pendingOrder.strike,type:pendingOrder.type,qty:pendingOrder.qty,execPrice:pendingOrder.ep,openPrice:match?.execPrice||null,expLbl:pendingOrder.expLbl,closedAt:now.toISOString(),execTime,openedAt:match?.openedAt||null,openExecTime:match?.execTime||null,status:'closed',tradeType:'btc',gain};
    trades.unshift(ct);if(mi>=0)openPos.splice(mi,1);
  }
  saveTrades();closeConf();renderPosAlert();renderPositions();renderGL();
  toast(pendingOrder.isSell?`✓ Sold ${pendingOrder.qty}× $${pendingOrder.strike} Put @ $${pendingOrder.ep.toFixed(2)}`:`✓ BTC @ $${pendingOrder.ep.toFixed(2)}`);
  pendingOrder=null;
}

function closeConf(){document.getElementById('conf-overlay').classList.remove('open');}
function closeConfOut(e){if(e.target===document.getElementById('conf-overlay'))closeConf();}

