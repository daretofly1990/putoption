<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
// ══════════════════════════════════════════
// STATE
// ══════════════════════════════════════════
let LD={qqq:null,bid:null,ask:null,vix:null,ma20:null,sma5:null,sma50:null,ema9:null,ema21:null,chg:null,pmChg:null,asOf:'',ok:false};
let OQ={bid:null,ask:null,last:null};
let OV={vix:'auto',trend:'auto',news:'none',pm:'auto'};
let trades=[],openPos=[],userRules={},pendingOrder=null,algoSig={},deferredPrompt=null;
let sigTimer=300,glSort={col:'dateClosed',dir:-1};
let newsCache={today:null,tomorrow:null};

// ══════════════════════════════════════════
// TABS
// ══════════════════════════════════════════
function showTab(id,btn){
  document.querySelectorAll('.tb').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('panel-'+id).classList.add('active');
  btn.classList.add('active');
  if(id==='stats')renderStats();
  if(id==='positions')renderPositions();
  if(id==='gains')renderGL();
  if(id==='order')renderSug();
}

// ══════════════════════════════════════════
// MARKET STATUS
// ══════════════════════════════════════════
function updateMktStatus(){
  const et=new Date(new Date().toLocaleString('en-US',{timeZone:'America/New_York'}));
  const h=et.getHours(),m=et.getMinutes(),s=et.getSeconds(),d=et.getDay();
  const mins=h*60+m;
  const dot=document.getElementById('mkt-dot'),lbl=document.getElementById('mkt-lbl');
  const ts=`${h%12||12}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')} ${h>=12?'PM':'AM'} ET`;
  if(d===0||d===6){dot.className='dot dc';lbl.textContent='Market Closed (Weekend)';}
  else if(mins>=570&&mins<960){dot.className='dot dl';lbl.textContent='Market Open · '+ts;}
  else if((mins>=480&&mins<570)||(mins>=960&&mins<1200)){dot.className='dot dp';lbl.textContent=(mins<570?'Pre':'After')+'-Market · '+ts;}
  else{dot.className='dot dc';lbl.textContent='Market Closed · '+ts;}
}

// ══════════════════════════════════════════
// LIVE DATA FETCH
// ══════════════════════════════════════════
async function callAPI(prompt,maxTok){
  const r=await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:maxTok||600,tools:[{type:'web_search_20250305',name:'web_search'}],messages:[{role:'user',content:prompt}]})
  });
  const d=await r.json();
  return d.content.filter(b=>b.type==='text').map(b=>b.text).join('');
}

async function fetchLD(){
  try{
    const txt=await callAPI('Search for current QQQ and VIX prices. Reply ONLY with JSON no markdown: {"qqq":609.90,"bid":609.85,"ask":609.95,"vix":19.5,"ma20":598.0,"sma5":611.0,"sma50":592.0,"ema9":608.0,"ema21":601.0,"chg_pct":0.31,"pm_chg":0.15,"as_of":"Apr 9 close"}',700);
    const jm=txt.match(/\{[\s\S]*?\}/);
    if(jm){
      const p=JSON.parse(jm[0]);
      LD={qqq:p.qqq,bid:p.bid||p.qqq-.05,ask:p.ask||p.qqq+.05,vix:p.vix,ma20:p.ma20,sma5:p.sma5,sma50:p.sma50,ema9:p.ema9,ema21:p.ema21,chg:p.chg_pct,pmChg:p.pm_chg,asOf:p.as_of||'now',ok:true};
      applyLD();
    }
  }catch(e){
    if(!LD.ok){
      LD={qqq:609.90,bid:609.85,ask:609.95,vix:19.5,ma20:598.0,sma5:611.0,sma50:592.0,ema9:608.0,ema21:601.0,chg:0.31,pmChg:0.15,asOf:'Apr 9 (cached)',ok:true};
      applyLD();
    }
  }
}

function applyLD(){
  const{qqq,bid,ask,vix,ma20,sma5,sma50,ema9,ema21,chg,pmChg,asOf}=LD;
  // Header
  document.getElementById('qqq-price').textContent='$'+qqq.toFixed(2);
  const ce=document.getElementById('price-chg');
  ce.textContent=(chg>=0?'+':'')+chg.toFixed(2)+'%';ce.style.color=chg>=0?'var(--gt)':'var(--rt)';
  document.getElementById('hdr-bid').textContent=bid.toFixed(2);
  document.getElementById('hdr-ask').textContent=ask.toFixed(2);
  document.getElementById('upd-lbl').textContent=asOf;
  // Pre-market
  if(OV.pm==='auto'){
    const pe=document.getElementById('pm-disp');
    const pmPct=pmChg||0;
    pe.textContent=(pmPct>=0?'+':'')+pmPct.toFixed(2)+'%';
    pe.style.color=pmPct>0?'var(--gt)':pmPct<-1.5?'var(--rt)':'var(--at)';
  }
  // VIX
  if(vix&&OV.vix==='auto'){
    const ve=document.getElementById('vix-disp');ve.textContent=vix.toFixed(1);
    ve.style.color=vix<15?'var(--gt)':vix<20?'var(--at)':'var(--rt)';
  }
  // Trend display
  if(qqq&&ma20&&OV.trend==='auto'){
    const diff=((qqq-ma20)/ma20*100).toFixed(1),te=document.getElementById('trend-disp');
    if(qqq>ma20*1.005){te.textContent='↑ +'+diff+'%';te.style.color='var(--gt)';}
    else if(qqq<ma20*.995){te.textContent='↓ '+diff+'%';te.style.color='var(--rt)';}
    else{te.textContent='→ Near MA';te.style.color='var(--at)';}
  }
  // QQQ Trend (SMA/EMA analysis)
  updateTrend();
  updateSig();renderSug();renderPosAlert();
}

function updateTrend(){
  const{qqq,sma5,sma20:_,ma20,sma50,ema9,ema21}=LD;
  if(!qqq)return;
  const s20=ma20||qqq*.98;
  let bullSignals=0,totalSignals=4;
  // SMA5 vs SMA20
  const s5=sma5||qqq;const d5_20=((s5-s20)/s20*100).toFixed(2);
  const b1=s5>s20;if(b1)bullSignals++;
  document.getElementById('t-sma5-20').textContent=(b1?'+':'')+d5_20+'%';
  document.getElementById('t-sma5-20-b').className='trend-badge '+(b1?'bull':'bear');
  document.getElementById('t-sma5-20-b').textContent=b1?'Bullish':'Bearish';
  // SMA20 vs SMA50
  const s50=sma50||qqq*.95;const d20_50=((s20-s50)/s50*100).toFixed(2);
  const b2=s20>s50;if(b2)bullSignals++;
  document.getElementById('t-sma20-50').textContent=(b2?'+':'')+d20_50+'%';
  document.getElementById('t-sma20-50-b').className='trend-badge '+(b2?'bull':'bear');
  document.getElementById('t-sma20-50-b').textContent=b2?'Bullish':'Bearish';
  // EMA9 vs EMA21
  const e9=ema9||qqq;const e21=ema21||s20;const de=((e9-e21)/e21*100).toFixed(2);
  const b3=e9>e21;if(b3)bullSignals++;
  document.getElementById('t-ema9-21').textContent=(b3?'+':'')+de+'%';
  document.getElementById('t-ema9-21-b').className='trend-badge '+(b3?'bull':'bear');
  document.getElementById('t-ema9-21-b').textContent=b3?'Bullish':'Bearish';
  // Price vs SMA20
  const dp=((qqq-s20)/s20*100).toFixed(2);
  const b4=qqq>s20;if(b4)bullSignals++;
  document.getElementById('t-price-sma20').textContent=(b4?'+':'')+dp+'%';
  document.getElementById('t-price-sma20-b').className='trend-badge '+(b4?'bull':'bear');
  document.getElementById('t-price-sma20-b').textContent=b4?'Above MA':'Below MA';
  // Overall
  const ov=document.getElementById('trend-overall');
  if(bullSignals>=3){ov.className='tag tg';ov.textContent='Bullish ('+bullSignals+'/'+totalSignals+')';}
  else if(bullSignals<=1){ov.className='tag tr2';ov.textContent='Bearish ('+bullSignals+'/'+totalSignals+')';}
  else{ov.className='tag ta';ov.textContent='Neutral ('+bullSignals+'/'+totalSignals+')';}
}

// Streaming simulation
function streamTick(){
  if(!LD.qqq)return;
  const chg=(Math.random()-.485)*.12;
  LD.qqq=Math.round((LD.qqq+chg)*100)/100;
  LD.bid=Math.round((LD.qqq-.05)*100)/100;
  LD.ask=Math.round((LD.qqq+.05)*100)/100;
  const pe=document.getElementById('qqq-price');
  pe.style.color=chg>=0?'var(--gt)':'var(--rt)';
  setTimeout(()=>pe.style.color='var(--gt)',400);
  pe.textContent='$'+LD.qqq.toFixed(2);
  document.getElementById('hdr-bid').textContent=LD.bid.toFixed(2);
  document.getElementById('hdr-ask').textContent=LD.ask.toFixed(2);
  document.getElementById('upd-lbl').textContent=new Date().toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit',second:'2-digit'});
  simOQ();renderPosAlert();
}

function simOQ(){
  const strike=parseFloat(document.getElementById('ot-strike').value);
  if(!strike||!LD.qqq)return;
  const otm=Math.max(0,strike-LD.qqq);
  const base=Math.max(0.01,otm*0.11+(Math.random()*.06+.01));
  const nb=Math.round((base-.02)*100)/100,na=Math.round((base+.02)*100)/100;
  const prev=OQ.bid;OQ={bid:nb,ask:na,last:Math.round(base*100)/100};
  function flash(el,up){el.classList.remove('flash-g','flash-r');void el.offsetWidth;el.classList.add(up?'flash-g':'flash-r');}
  if(prev!==null){flash(document.getElementById('qt-bid'),nb>=prev);flash(document.getElementById('qt-ask'),na>=prev);}
  document.getElementById('qt-bid-v').textContent='$'+nb.toFixed(2);
  document.getElementById('qt-bid-s').textContent='×'+Math.floor(Math.random()*50+10);
  document.getElementById('qt-ask-v').textContent='$'+na.toFixed(2);
  document.getElementById('qt-ask-s').textContent='×'+Math.floor(Math.random()*30+5);
  document.getElementById('qt-last-v').textContent='$'+OQ.last.toFixed(2);
  onTick();
}

