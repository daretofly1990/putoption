function onGLPeriod(){
  const v=document.getElementById('gl-period').value;
  const now=new Date(),fmt=d=>d.toISOString().split('T')[0];
  const from=document.getElementById('gl-from'),to=document.getElementById('gl-to');
  if(v==='today'){from.value=fmt(now);to.value=fmt(now);}
  else if(v==='week'){const s=new Date(now);s.setDate(now.getDate()-now.getDay());from.value=fmt(s);to.value=fmt(now);}
  else if(v==='month'){from.value=now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0')+'-01';to.value=fmt(now);}
  else if(v==='ytd'){from.value=now.getFullYear()+'-01-01';to.value=fmt(now);}
  else if(v==='all'){from.value='2000-01-01';to.value=fmt(now);}
  renderGL();
}

function sortGL(col){
  if(glSort.col===col)glSort.dir*=-1;else{glSort.col=col;glSort.dir=-1;}
  renderGL();
}

function renderGL(){
  const from=document.getElementById('gl-from').value;
  const to=document.getElementById('gl-to').value;
  // Filter closed trades
  let cl=trades.filter(t=>t.status==='closed'||t.tradeType==='btc');
  if(from)cl=cl.filter(t=>t.closedAt&&t.closedAt>=from);
  if(to)cl=cl.filter(t=>t.closedAt&&t.closedAt<=to+'T23:59:59');

  // Also include historical trades from CSV data (simulated)
  const hist=getHistoricalTrades().filter(t=>{
    if(from&&t.dateClosed<from)return false;
    if(to&&t.dateClosed>to)return false;
    return true;
  });
  const allTrades=[...cl.map(t=>({
    symbol:t.symbol||'QQQ Option',subLabel:'Buy to Close',qty:t.qty,
    dateAdded:t.closedAt?new Date(t.closedAt).toLocaleDateString():'—',
    costShare:t.execPrice||0,totalCost:Math.round((t.execPrice||0)*100*t.qty*100)/100,
    dateClosed:t.openedAt?new Date(t.openedAt).toLocaleDateString():'—',
    priceShare:t.openPrice||0,proceeds:t.openPrice?Math.round(t.openPrice*100*t.qty*100)/100:0,
    gain:t.gain||0,deferred:0,term:'Short',lotSel:'FIFO',isMyTrade:true
  })),...hist];

  // Sort
  const col=glSort.col,dir=glSort.dir;
  allTrades.sort((a,b)=>{const av=a[col],bv=b[col];return typeof av==='number'?(av-bv)*dir:(String(av).localeCompare(String(bv)))*dir;});

  // Compute summary
  const totalGain=allTrades.reduce((s,t)=>s+t.gain,0);
  const fees=allTrades.reduce((s,t)=>s+(t.isMyTrade?1.5:0),0);
  document.getElementById('gl-total').textContent=(totalGain>=0?'+$':'-$')+Math.abs(totalGain).toFixed(2);
  document.getElementById('gl-total').className='gl-met-val '+(totalGain>=0?'green':'red');
  document.getElementById('gl-st').textContent=(totalGain>=0?'+$':'-$')+Math.abs(totalGain).toFixed(2);
  document.getElementById('gl-lt').textContent='$0.00';
  document.getElementById('gl-def').textContent='$0.00';
  document.getElementById('gl-fees').textContent='$'+fees.toFixed(2);

  // Render table
  const tbody=document.getElementById('gl-body');
  if(!allTrades.length){tbody.innerHTML=`<tr><td colspan="12" style="text-align:center;padding:24px;color:var(--text3)">No trades in this date range</td></tr>`;return;}
  tbody.innerHTML=allTrades.map(t=>{
    const gc=t.gain>=0?'green':'red';
    return `<tr>
      <td><div class="gl-sym">${t.symbol}</div><div class="gl-sub">${t.subLabel||'Buy to Close'}</div></td>
      <td style="font-weight:700">${t.qty}</td>
      <td>${t.dateAdded||'—'}</td>
      <td>${t.costShare?'$'+Number(t.costShare).toFixed(3):'—'}</td>
      <td>${t.totalCost?'$'+Number(t.totalCost).toFixed(2):'—'}</td>
      <td>${t.dateClosed||'—'}</td>
      <td>${t.priceShare?'$'+Number(t.priceShare).toFixed(3):'—'}</td>
      <td>${t.proceeds?'$'+Number(t.proceeds).toFixed(2):'—'}</td>
      <td class="${gc}" style="font-weight:800">${t.gain>=0?'+$':'-$'}${Math.abs(t.gain).toFixed(2)}</td>
      <td>${t.deferred>0?'$'+t.deferred.toFixed(2):'0.00'}</td>
      <td><span class="tag ${t.term==='Short'?'ta':'tg'}">${t.term}</span></td>
      <td style="color:var(--text3)">${t.lotSel||'FIFO'}</td>
    </tr>`;
  }).join('');
}

