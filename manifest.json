// NEWS SCANNER
// ══════════════════════════════════════════
const NEWS_CATEGORIES=[
  'Economic Data Releases (GDP, CPI, jobs, PMI)',
  'Corporate Earnings and Guidance for QQQ components (Apple, Microsoft, Nvidia, Meta, Amazon, Google, Tesla)',
  'Fiscal Policy and Government Actions (tariffs, spending, debt)',
  'Geopolitical Events (conflicts, sanctions, trade wars)',
  'Commodity Price Movements (crude oil, natural gas, gold, copper)',
  'Market Sentiment and Investor Behavior (VIX, put/call ratio, fund flows)',
  'Technological Innovations and Industry Disruptions (AI, semiconductors)',
  'Interest Rates and Bond Market Movements (Fed, Treasury yields)',
  'Public Health Events',
  'Liquidity and Money Supply (Fed balance sheet, repo market)',
  'Market Structure and Technical Factors (circuit breakers, options expiration)'
];

function catClass(cat){
  if(cat.includes('Econom'))return 'nc-econ';
  if(cat.includes('Earning')||cat.includes('Corporate'))return 'nc-earn';
  if(cat.includes('Geopolit'))return 'nc-geo';
  if(cat.includes('Interest')||cat.includes('Rate')||cat.includes('Bond'))return 'nc-rate';
  if(cat.includes('Tech')||cat.includes('Innov'))return 'nc-tech';
  if(cat.includes('Commodity'))return 'nc-comm';
  if(cat.includes('Fiscal')||cat.includes('Government'))return 'nc-fiscal';
  return 'nc-mkt';
}
function catShort(cat){
  if(cat.includes('Econom'))return 'Economic';
  if(cat.includes('Earning'))return 'Earnings';
  if(cat.includes('Geopolit'))return 'Geopolitical';
  if(cat.includes('Interest')||cat.includes('Bond'))return 'Rates/Bonds';
  if(cat.includes('Tech'))return 'Tech/AI';
  if(cat.includes('Commodity'))return 'Commodities';
  if(cat.includes('Fiscal'))return 'Fiscal Policy';
  if(cat.includes('Market Sent'))return 'Sentiment';
  if(cat.includes('Public Health'))return 'Health';
  if(cat.includes('Liquidity'))return 'Liquidity';
  return 'Market';
}

async function fetchNews(which){
  const el=document.getElementById('news-'+which);
  el.innerHTML='<div class="news-loading"><span class="spin"></span>Scanning '+which+'\'s market news...</div>';
  const today=new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
  const tomorrow=new Date(Date.now()+86400000).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
  const dateStr=which==='today'?today:tomorrow;
  const verb=which==='today'?'Search for the latest news and events from today':'Search for upcoming events and news expected tomorrow or in the next 24 hours';
  const prompt=`${verb} (${dateStr}) that could affect the stock market, especially QQQ/Nasdaq. Cover these categories: ${NEWS_CATEGORIES.join('; ')}. Find the top 10 most market-moving items. Reply ONLY with a JSON array no markdown:
[{"headline":"Fed holds rates steady at 4.25-4.5%","category":"Interest Rates and Bond Market","time":"2:00 PM ET","impact":"HIGH"},{"headline":"Nvidia beats earnings, raises guidance","category":"Corporate Earnings","time":"4:30 PM ET","impact":"HIGH"}]
Impact must be HIGH, MEDIUM, or LOW. Include real, specific details. Latest/most impactful first.`;
  try{
    const txt=await callAPI(prompt,1500);
    const jm=txt.match(/\[[\s\S]*?\]/);
    if(jm){
      const items=JSON.parse(jm[0]).slice(0,10);
      newsCache[which]=items;
      renderNewsItems(el,items);
    } else throw new Error('no json');
  }catch(e){
    el.innerHTML='<div class="news-loading" style="color:var(--rt)">Failed to load news. <button onclick="fetchNews(\''+which+'\')" style="background:none;border:1px solid var(--border2);border-radius:4px;padding:2px 8px;font-size:10px;color:var(--text3);cursor:pointer;margin-left:4px">Retry</button></div>';
  }
}

function renderNewsItems(el,items){
  if(!items||!items.length){el.innerHTML='<div class="news-loading">No major news found</div>';return;}
  el.innerHTML=items.map(item=>{
    const impCls=item.impact==='HIGH'?'ni-high':item.impact==='MEDIUM'?'ni-med':'ni-low';
    const cCls=catClass(item.category||'');
    const cShort=catShort(item.category||'');
    return `<div class="news-item">
      <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;flex-wrap:wrap">
        <span class="news-cat ${cCls}">${cShort}</span>
        <span class="news-impact ${impCls}">${item.impact}</span>
        <span class="news-time">${item.time||''}</span>
      </div>
      <div class="news-headline">${item.headline}</div>
    </div>`;
  }).join('');
}

// ══════════════════════════════════════════
// SIGNAL ENGINE
// ══════════════════════════════════════════
function getVL(){if(OV.vix!=='auto')return OV.vix;const v=LD.vix;if(!v)return 'mid';return v<15?'low':v<20?'mid':v<25?'high':'extreme';}
function getTR(){if(OV.trend!=='auto')return OV.trend;if(!LD.qqq||!LD.ma20)return 'up';const r=LD.qqq/LD.ma20;return r>1.005?'up':r<.995?'down':'flat';}
function getPM(){if(OV.pm!=='auto')return OV.pm;const c=LD.pmChg||0;return c>=-0.5?'up':c>=-1.5?'down1':'down2';}

function updateSig(){
  const vix=getVL(),trend=getTR(),pm=getPM(),spot=LD.qqq||609.90;
  const isRed=vix==='extreme'||trend==='down'||pm==='down2'||OV.news==='major';
  const isAmber=!isRed&&(vix==='high'||trend==='flat'||pm==='down1'||OV.news==='minor');
  document.getElementById('sig-rec').style.display='block';
  let sig={};
  if(isRed){
    document.getElementById('sig-card').className='sig sig-r';
    document.getElementById('sig-lbl-text').textContent='✗ RED LIGHT';
    document.getElementById('sig-title').textContent='Skip Today — Unfavorable';
    document.getElementById('sig-desc').textContent='High-risk conditions active. Your 5 largest losses all occurred in these conditions.';
    document.getElementById('sig-rec-body').textContent='Sit in cash. Capital protection is the trade today.';
    sig={action:'skip'};
  } else if(isAmber){
    const otm=15,strike=Math.floor((spot-otm)/5)*5;
    document.getElementById('sig-card').className='sig sig-a';
    document.getElementById('sig-lbl-text').textContent='⚠ YELLOW LIGHT';
    document.getElementById('sig-title').textContent=`Sell $${strike} Put — Reduced Size`;
    document.getElementById('sig-desc').textContent=`${otm}pts OTM · $0.35–$0.70/sh · ~10 contracts (−30%) · Stop 2× · Exit 15%`;
    document.getElementById('sig-rec-body').textContent=`Elevated conditions lower win rate to ~83%. Extra OTM buffer compensates. Exit quickly at 15% of premium.`;
    sig={action:'sell_put',strike,otm,premRange:'$0.35–$0.70',contracts:10};
  } else {
    const otm=vix==='low'?8:10,strike=Math.floor((spot-otm)/5)*5;
    const pr=vix==='low'?'$0.20–$0.50':'$0.30–$0.70';
    document.getElementById('sig-card').className='sig sig-g';
    document.getElementById('sig-lbl-text').textContent='✓ GREEN LIGHT';
    document.getElementById('sig-title').textContent=`Sell $${strike} Put`;
    document.getElementById('sig-desc').textContent=`QQQ ~$${spot.toFixed(2)} · ${otm}pts OTM · Target ${pr}/sh · 15 contracts · Exit 15% of prem · Stop 2×`;
    document.getElementById('sig-rec-body').textContent=`Ideal conditions. 91% win rate from ≤$0.50 premium, ${otm}pts OTM, 1DTE setups. Target BTC at 15% of premium ($0.05–$0.10 range).`;
    sig={action:'sell_put',strike,otm,premRange:pr,contracts:15};
  }
  algoSig=sig;
}

function onOv(){
  OV.vix=document.getElementById('vix-sel').value;
  OV.trend=document.getElementById('trend-sel').value;
  OV.pm=document.getElementById('pm-sel').value;
  if(OV.vix!=='auto'){const m={low:'<15',mid:'15–20',high:'20–25',extreme:'>25'};document.getElementById('vix-disp').textContent=m[OV.vix];}
  if(OV.trend!=='auto'){const m={up:'↑ Above',flat:'→ Near',down:'↓ Below'};document.getElementById('trend-disp').textContent=m[OV.trend];}
  if(OV.pm!=='auto'){const m={up:'Up/flat',down1:'Down 0.5–1.5%',down2:'Down >1.5%'};document.getElementById('pm-disp').textContent=m[OV.pm];}
  updateSig();renderSug();
}

function getNextExp(){
  const et=new Date(new Date().toLocaleString('en-US',{timeZone:'America/New_York'}));
  et.setDate(et.getDate()+1);if(et.getDay()===0)et.setDate(et.getDate()+1);if(et.getDay()===6)et.setDate(et.getDate()+2);
  return et.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'2-digit'});
}

function startCountdown(){
  let t=300;
  setInterval(()=>{t--;const m=Math.floor(t/60),s=t%60;const el=document.getElementById('sig-cd');if(el)el.textContent=m+':'+String(s).padStart(2,'0');if(t<=0){t=300;fetchLD();updateSig();}},1000);
}

// ══════════════════════════════════════════
// OPEN POSITION ALERT
// ══════════════════════════════════════════
function renderPosAlert(){
  const wrap=document.getElementById('pos-alert-wrap');
  if(!openPos.length){wrap.innerHTML='';return;}
  let html='';
  openPos.forEach((pos,i)=>{
    const spot=LD.qqq||pos.execPrice;const curBid=OQ.bid||pos.execPrice*.5;
    const ptsOTM=spot-pos.strike;const unreal=Math.round((pos.execPrice-curBid)*100*pos.qty*100)/100;
    const isStop=curBid>=pos.execPrice*2,isTarget=curBid<=pos.execPrice*.15,isClose=ptsOTM<=3&&ptsOTM>=0;
    let cls='pa-hold',title='',body='';
    if(isStop){cls='pa-close';title='⚠ STOP LOSS HIT — Close Now';body=`$${pos.strike} Put: 2× stop triggered ($${pos.execPrice.toFixed(2)} → $${curBid.toFixed(2)}). Est loss: -$${Math.abs(unreal).toLocaleString()}`;}
    else if(isTarget){cls='pa-profit';title='✓ Profit Target Reached';body=`BTC at $${curBid.toFixed(2)} locks in +$${unreal.toLocaleString()} (${Math.round((1-curBid/pos.execPrice)*100)}% of max).`;}
    else if(isClose){cls='pa-close';title='⚠ Near Strike — Monitor';body=`QQQ $${spot.toFixed(2)} is ${ptsOTM.toFixed(1)}pts above $${pos.strike} strike. Consider rolling if stable.`;}
    else{title=`Holding $${pos.strike} Put`;body=`QQQ $${spot.toFixed(2)}, ${ptsOTM.toFixed(1)}pts OTM. Unrealized: ${unreal>=0?'+':''}$${unreal.toLocaleString()}`;}
    html+=`<div class="pa ${cls}" style="margin-bottom:10px">
      <div class="pa-title">${title}</div><div class="pa-body">${body}</div>
      ${(isStop||isTarget)?`<button onclick="quickClose(${i})" style="margin-top:8px;background:var(--red);color:#fff;border:none;border-radius:var(--rs);padding:8px 14px;font-size:12px;font-weight:800;cursor:pointer;width:100%">Quick BTC @ $${curBid.toFixed(2)}</button>`:''}
    </div>`;
  });
  wrap.innerHTML=html;
}

function quickClose(i){
  const pos=openPos[i];const cp=OQ.bid||pos.execPrice*.15;
  const gain=Math.round((pos.execPrice-cp)*100*pos.qty*100)/100;
  const now=new Date();
  trades.unshift({...pos,closePrice:cp,execPrice:cp,openPrice:pos.execPrice,gain,closedAt:now.toISOString(),execTime:now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'}),tradeType:'btc',status:'closed'});
  openPos.splice(i,1);saveTrades();renderPositions();renderPosAlert();renderGL();
  toast(`BTC $${cp.toFixed(2)}/sh · P&L: ${gain>=0?'+':''}$${gain.toLocaleString()}`);
}

