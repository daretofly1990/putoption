// TOAST / PWA
// ══════════════════════════════════════════
function toast(msg){const el=document.getElementById('toast');el.textContent=msg;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),2500);}
window.addEventListener('beforeinstallprompt',e=>{e.preventDefault();deferredPrompt=e;document.getElementById('ibanner').classList.add('show');});
function installApp(){if(deferredPrompt){deferredPrompt.prompt();deferredPrompt.userChoice.then(()=>{deferredPrompt=null;dismissInstall();});}}
function dismissInstall(){document.getElementById('ibanner').classList.remove('show');}

// ══════════════════════════════════════════
// INIT
// ══════════════════════════════════════════
window.addEventListener('load',()=>{
  loadRules();renderAR();
  loadTrades();
  populateExp();
  renderChart();
  // Set default GL date range to current month
  const now=new Date();
  document.getElementById('gl-from').value=now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0')+'-01';
  document.getElementById('gl-to').value=now.toISOString().split('T')[0];
  updateMktStatus();setInterval(updateMktStatus,1000);
  fetchLD();setInterval(fetchLD,300000);
  startCountdown();
  setInterval(streamTick,2000);
  setInterval(()=>{if(openPos.length)renderPosAlert();},5000);
  // Fetch news
  setTimeout(()=>fetchNews('today'),2000);
  setTimeout(()=>fetchNews('tomorrow'),5000);
  // Refresh news every 15 min
  setInterval(()=>fetchNews('today'),900000);
  setInterval(()=>fetchNews('tomorrow'),900000);
});
