// POSITIONS TABLE
// ══════════════════════════════════════════
function renderPositions(){
  renderOpenPositions();renderClosedPositions();
}

function renderOpenPositions(){
  const tbody=document.getElementById('pos-open-body');
  const tfoot=document.getElementById('pos-open-foot');
  if(!openPos.length){
    tbody.innerHTML=`<tr><td colspan="11" style="text-align:center;padding:24px;color:var(--text3)">No open positions</td></tr>`;
    tfoot.innerHTML='';return;
  }
  let totalVal=0,totalDayGain=0,totalGain=0,totalQty=0,cash=119784.20;
  tbody.innerHTML=openPos.map(pos=>{
    const spot=LD.qqq||pos.execPrice;
    const last=OQ.last||pos.execPrice*.8;
    const chgDollar=Math.round((last-pos.execPrice)*100)/100;
    const chgPct=Math.round((last-pos.execPrice)/pos.execPrice*10000)/100;
    const qty=-pos.qty; // short position shown negative
    const dayGain=Math.round((pos.execPrice-last)*100*pos.qty*100)/100;
    const totalGainPos=Math.round((pos.execPrice-last)*100*pos.qty*100)/100;
    const totalGainPct=Math.round((pos.execPrice-last)/pos.execPrice*10000)/100;
    const value=Math.round(last*100*pos.qty*100)/100 * -1;
    totalVal+=value;totalDayGain+=dayGain;totalGain+=totalGainPos;totalQty+=qty;
    const dg=dayGain>=0?'green':'red',tg=totalGainPos>=0?'green':'red';
    return `<tr>
      <td><div class="pos-table"><div class="sym-cell">${pos.symbol}</div><div class="sym-sub">${new Date(pos.openedAt).toLocaleDateString()} ${pos.execTime||''}</div></div></td>
      <td><button class="act-btn" onclick="">Trade</button></td>
      <td style="font-weight:700">$${last.toFixed(2)}</td>
      <td class="${dg}">${chgDollar>=0?'+':''}$${Math.abs(chgDollar).toFixed(2)}</td>
      <td class="${dg}">${chgPct>=0?'+':''}${chgPct.toFixed(2)}%</td>
      <td style="font-weight:700">${qty}</td>
      <td>$${pos.execPrice.toFixed(2)}</td>
      <td class="${dg}">${dayGain>=0?'+':''}$${dayGain.toFixed(2)}</td>
      <td class="${tg}">${totalGainPos>=0?'+':''}$${totalGainPos.toFixed(2)}</td>
      <td class="${tg}">${totalGainPct>=0?'+':''}${totalGainPct.toFixed(2)}%</td>
      <td>${value>=0?'':'−'}$${Math.abs(value).toFixed(2)}</td>
    </tr>`;
  }).join('');
  const totalAll=totalVal+cash;
  tfoot.innerHTML=`
    <tr class="pos-footer"><td>Cash</td><td colspan="9" style="color:var(--blue-t);font-size:11px">Transfer money</td><td>$${cash.toLocaleString()}</td></tr>
    <tr class="pos-footer"><td>Total</td><td></td><td></td><td></td><td></td><td style="font-weight:800">${totalQty}</td><td></td><td class="${totalDayGain>=0?'green':'red'}">${totalDayGain>=0?'+':''}$${totalDayGain.toFixed(2)}</td><td class="${totalGain>=0?'green':'red'}">${totalGain>=0?'+':''}$${totalGain.toFixed(2)}</td><td class="${totalGain>=0?'green':'red'}">${totalGain>=0?'+':''}${openPos.length?Math.round(totalGain/(openPos.reduce((s,p)=>s+p.execPrice*p.qty*100,0))*10000)/100:0}%</td><td style="font-weight:800">$${totalAll.toLocaleString()}</td></tr>`;
}

function renderClosedPositions(){
  const tbody=document.getElementById('pos-closed-body');
  const cl=trades.filter(t=>t.status==='closed'||t.tradeType==='btc');
  if(!cl.length){tbody.innerHTML=`<tr><td colspan="9" style="text-align:center;padding:24px;color:var(--text3)">No closed trades</td></tr>`;return;}
  tbody.innerHTML=cl.slice(0,30).map(t=>{
    const gp=t.gain&&t.openPrice?Math.round(t.gain/(t.openPrice*100*t.qty)*10000)/100:null;
    const gc=t.gain>=0?'green':'red';
    return `<tr>
      <td><div class="sym-cell">${t.symbol||'QQQ Option'}</div></td>
      <td>${t.openedAt?new Date(t.openedAt).toLocaleDateString():'—'}</td>
      <td style="color:var(--text3)">${t.openExecTime||t.execTime||'—'}</td>
      <td>${t.closedAt?new Date(t.closedAt).toLocaleDateString():'—'}</td>
      <td>${t.qty}</td>
      <td>${t.openPrice?'$'+t.openPrice.toFixed(2):'—'}</td>
      <td>$${t.execPrice.toFixed(2)}</td>
      <td class="${gc}">${t.gain!==null?((t.gain>=0?'+':'')+'$'+t.gain.toLocaleString()):'—'}</td>
      <td class="${gc}">${gp!==null?((gp>=0?'+':'')+gp.toFixed(2)+'%'):'—'}</td>
    </tr>`;
  }).join('');
}

// ══════════════════════════════════════════
