// RULES EDITOR
// ══════════════════════════════════════════
const DR={
  entry:[
    {color:'b',title:'1. Check market regime',body:"QQQ vs 20-day MA. Only sell puts in uptrend or sideways. Avoid confirmed downtrend."},
    {color:'b',title:'2. OTM distance by VIX',body:'VIX<15→8–10pts. VIX 15–20→10–12pts. VIX 20–25→15–20pts. VIX>25→skip.'},
    {color:'b',title:'3. Round to nearest $5 strike',body:'Spot − OTM distance, floored to nearest $5 for best liquidity.'},
    {color:'b',title:'4. Confirm premium sweet spot',body:'Target $0.20–$0.80/share. 91% win rate from ≤$0.50 premium trades.'},
    {color:'b',title:'5. Open after 10am ET',body:'Avoid opening gap volatility. Sell next-day (1DTE) expiration.'}
  ],
  filters:[
    {color:'g',title:'✓ Green — Trade normally',body:'QQQ above 20MA · VIX<18 · No major catalyst · Pre-market up/flat'},
    {color:'a',title:'⚠ Yellow — Further OTM, reduce 30%',body:'QQQ within 1% of 20MA · VIX 18–25 · Possible news event'},
    {color:'r',title:'✗ Red — Skip',body:'QQQ below 20MA · VIX>25 · Fed/CPI day · QQQ down >1.5% open'},
    {color:'b',title:'Sizing rule',body:"Max risk = 2% of account. Growth: 6→15 contracts over 10 months."}
  ],
  profit:[
    {color:'g',title:'BTC at 10–20% of premium',body:'Median exit: 15% of premium. Sold $0.50→BTC at $0.05–$0.10.'},
    {color:'g',title:'Let expire if OTM, <2hrs left',body:'49 of 201 trades expired worthless. 5+pts OTM under 2hrs→let expire.'},
    {color:'b',title:'Early re-entry if decay 50%+ by noon',body:'Close early, re-enter same day at different strike.'}
  ],
  stop:[
    {color:'r',title:'Hard stop: 2× premium — no exceptions',body:'All 5 biggest losses blew past this. Would have saved ~$20,000.'},
    {color:'a',title:'Roll trigger: within 3pts of strike',body:'With >2hrs left: close, sell next day −5–8pts OTM.'},
    {color:'r',title:'Never roll in free-fall (>2% drop)',body:"Mar '26 (−$5,579) and Apr '26 (−$2,806) both worsened on rolling."},
    {color:'a',title:'VIX spike response',body:'VIX surges >25 intraday→close immediately.'}
  ]
};
function loadRules(){try{userRules=JSON.parse(localStorage.getItem('qqq-rules-v4')||'{}');}catch{userRules={};}}
function saveRD(){localStorage.setItem('qqq-rules-v4',JSON.stringify(userRules));}
function renderRules(cid,key){
  const el=document.getElementById(cid);if(!el)return;
  const rules=DR[key].map((d,i)=>({...d,...((userRules[key]&&userRules[key][i])||{})}));
  el.innerHTML=rules.map((r,i)=>`<div class="rule-block rule-${r.color}">
    <div class="rule-title-row"><div class="rule-title-text">${r.title}</div><button class="edit-btn" onclick="toggleEdit('${cid}',${i})">Edit</button></div>
    <div class="rule-body" id="rb-${cid}-${i}">${r.body}</div>
    <div class="rule-edit-area" id="rea-${cid}-${i}">
      <textarea class="rule-ta" id="rt-${cid}-${i}" rows="3">${r.body}</textarea>
      <div class="rule-edit-btns">
        <button class="btn-sr" onclick="saveRule('${cid}','${key}',${i})">Save</button>
        <button class="btn-cr" onclick="toggleEdit('${cid}',${i})">Cancel</button>
        <button class="btn-rr" onclick="resetSR('${cid}','${key}',${i})">Reset</button>
      </div>
    </div></div>`).join('');
}
function toggleEdit(cid,i){document.getElementById(`rea-${cid}-${i}`).classList.toggle('open');}
function saveRule(cid,key,i){const v=document.getElementById(`rt-${cid}-${i}`).value.trim();if(!userRules[key])userRules[key]={};userRules[key][i]={body:v};saveRD();renderAR();toast('Rule saved ✓');}
function resetSR(cid,key,i){if(userRules[key])delete userRules[key][i];saveRD();renderAR();toast('Reset ✓');}
function resetRules(tab){const keys=tab==='entry'?['entry','filters']:['profit','stop'];keys.forEach(k=>delete userRules[k]);saveRD();renderAR();toast('All rules reset');}
function renderAR(){renderRules('entry-rules-c','entry');renderRules('entry-filters-c','filters');renderRules('exit-profit-c','profit');renderRules('exit-stop-c','stop');}

