<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="QQQ Algo">
<meta name="theme-color" content="#1a1a2e">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<title>QQQ Put Algo</title>
<style>
:root{--bg:#1a1a2e;--bg2:#22223a;--bg3:#2d2d48;--bg4:#383858;--border:rgba(255,255,255,0.18);--border2:rgba(255,255,255,0.30);--text:#ffffff;--text2:#d8d8ee;--text3:#a8a8c8;--green:#22c98a;--gbg:rgba(34,201,138,0.18);--gt:#4eedb0;--red:#ff5f5e;--rbg:rgba(255,95,94,0.18);--rt:#ff8888;--amber:#ffbe3d;--abg:rgba(255,190,61,0.18);--at:#ffd166;--blue:#4fa3f7;--bbg:rgba(79,163,247,0.18);--bt:#7ec0ff;--r:12px;--rs:8px}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:-apple-system,'SF Pro Text','Helvetica Neue',sans-serif;overflow:hidden;font-size:14px}
#app{display:flex;flex-direction:column;height:100vh;height:100dvh}

/* HEADER */
#hdr{padding:44px 16px 8px;background:var(--bg);border-bottom:1px solid var(--border);flex-shrink:0}
#hdr-row{display:flex;align-items:flex-start;justify-content:space-between;gap:8px}
#hdr h1{font-size:15px;font-weight:800;letter-spacing:-.4px}
.sub{font-size:11px;color:var(--text3);margin-top:2px}
#price-block{text-align:right;flex-shrink:0;min-width:120px}
#qqq-price{font-size:26px;font-weight:800;color:var(--gt);font-variant-numeric:tabular-nums;line-height:1;letter-spacing:-.5px;transition:color .3s}
#price-meta{display:flex;flex-direction:column;align-items:flex-end;gap:2px;margin-top:3px}
#price-chg{font-size:12px;font-weight:800;font-variant-numeric:tabular-nums}
#ba-row{display:flex;gap:10px}
.ba{font-size:11px;font-variant-numeric:tabular-nums;font-weight:600}
.ba-l{color:var(--text3);font-weight:700}
#mkt-row{display:flex;align-items:center;gap:5px;margin-top:5px}
.dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.dl{background:var(--green);animation:pu 2s infinite}.dp{background:var(--amber)}.dc{background:var(--rt)}
@keyframes pu{0%,100%{opacity:1}50%{opacity:.3}}
#mkt-lbl{font-size:10px;color:var(--text3);font-weight:600}
#upd-lbl{font-size:9px;color:var(--text3);text-align:right;margin-top:1px}

/* TABS */
#tabs{display:flex;overflow-x:auto;scrollbar-width:none;background:var(--bg);border-bottom:1px solid var(--border);flex-shrink:0}
#tabs::-webkit-scrollbar{display:none}
.tb{flex-shrink:0;padding:9px 12px;font-size:11px;font-weight:700;color:var(--text3);background:none;border:none;border-bottom:2.5px solid transparent;cursor:pointer;white-space:nowrap;letter-spacing:.01em}
.tb.active{color:var(--text);border-bottom-color:var(--gt)}

/* CONTENT */
#content{flex:1;overflow-y:auto;overscroll-behavior:contain;-webkit-overflow-scrolling:touch}
.panel{display:none;padding:14px 14px 52px}.panel.active{display:block}

/* SHARED */
.stitle{font-size:10px;font-weight:800;color:var(--text3);text-transform:uppercase;letter-spacing:.09em;margin:0 0 8px}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:13px 15px;margin-bottom:12px}
.row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px;gap:8px}
.row:last-child{border-bottom:none}
.rl{color:var(--text2);flex-shrink:0}.rv{font-weight:600;text-align:right}
.tag{display:inline-block;font-size:10px;font-weight:800;padding:2px 8px;border-radius:20px}
.tg{background:var(--gbg);color:var(--gt)}.tr2{background:var(--rbg);color:var(--rt)}.ta{background:var(--abg);color:var(--at)}.tb2{background:var(--bbg);color:var(--bt)}
.mg{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.mg4{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:12px}
.mg5{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-bottom:12px}
.met{background:var(--bg3);border-radius:var(--rs);padding:10px 11px}
.ml{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px;font-weight:700}
.mv{font-size:16px;font-weight:800;font-variant-numeric:tabular-nums}
.ms{font-size:9px;color:var(--text3);margin-top:2px}
.green{color:var(--gt)}.red{color:var(--rt)}.amber{color:var(--at)}.blue{color:var(--bt)}

/* SIGNAL */
.sig{border-radius:var(--r);padding:16px;margin-bottom:12px;border:1.5px solid transparent}
.sig-g{background:var(--gbg);border-color:rgba(34,201,138,.35)}
.sig-a{background:var(--abg);border-color:rgba(255,190,61,.35)}
.sig-r{background:var(--rbg);border-color:rgba(255,95,94,.35)}
.sig-lbl{font-size:10px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;margin-bottom:5px;display:flex;align-items:center;justify-content:space-between}
.sig-g .sig-lbl{color:var(--gt)}.sig-a .sig-lbl{color:var(--at)}.sig-r .sig-lbl{color:var(--rt)}
.sig-title{font-size:18px;font-weight:800;margin-bottom:6px;line-height:1.2}
.sig-desc{font-size:12px;color:var(--text2);line-height:1.6}
.sig-rec{margin-top:10px;padding:9px 11px;background:rgba(0,0,0,.3);border-radius:var(--rs)}
.sig-rec-lbl{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;font-weight:800}
.sig-rec-body{font-size:12px;color:var(--text2);line-height:1.55}
.cd-badge{font-size:11px;font-weight:700;color:var(--at);background:var(--abg);padding:2px 8px;border-radius:10px;white-space:nowrap}

/* POS ALERT */
.pa{border-radius:var(--r);padding:14px;margin-bottom:12px;border:1.5px solid}
.pa-hold{background:rgba(79,163,247,.12);border-color:rgba(79,163,247,.35)}
.pa-close{background:var(--rbg);border-color:rgba(255,95,94,.35)}
.pa-profit{background:var(--gbg);border-color:rgba(34,201,138,.35)}
.pa-title{font-size:13px;font-weight:800;margin-bottom:4px}
.pa-body{font-size:12px;color:var(--text2);line-height:1.5}

/* NEWS */
.news-item{padding:10px 0;border-bottom:1px solid var(--border)}
.news-item:last-child{border-bottom:none}
.news-cat{display:inline-block;font-size:9px;font-weight:800;padding:2px 6px;border-radius:4px;margin-bottom:4px;text-transform:uppercase;letter-spacing:.05em}
.nc-econ{background:rgba(79,163,247,.2);color:var(--bt)}
.nc-earn{background:rgba(255,190,61,.2);color:var(--at)}
.nc-geo{background:rgba(255,95,94,.2);color:var(--rt)}
.nc-rate{background:rgba(34,201,138,.2);color:var(--gt)}
.nc-tech{background:rgba(138,79,247,.2);color:#c084fc}
.nc-comm{background:rgba(234,179,8,.2);color:#fde047}
.nc-mkt{background:rgba(156,163,175,.2);color:#d1d5db}
.nc-fiscal{background:rgba(239,68,68,.2);color:#fca5a5}
.news-headline{font-size:13px;font-weight:600;color:var(--text);line-height:1.4;margin-bottom:2px}
.news-time{font-size:10px;color:var(--text3)}
.news-impact{display:inline-block;font-size:9px;font-weight:800;padding:1px 5px;border-radius:3px;margin-left:4px}
.ni-high{background:var(--rbg);color:var(--rt)}
.ni-med{background:var(--abg);color:var(--at)}
.ni-low{background:var(--gbg);color:var(--gt)}
.news-loading{text-align:center;padding:20px;color:var(--text3);font-size:12px}
.spin{display:inline-block;width:14px;height:14px;border:2px solid var(--border2);border-top-color:var(--gt);border-radius:50%;animation:sp .6s linear infinite;margin-right:6px;vertical-align:middle}
@keyframes sp{to{transform:rotate(360deg)}}

/* TREND */
.trend-block{display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border);font-size:12px}
.trend-block:last-child{border-bottom:none}
.trend-name{color:var(--text2);font-weight:600}
.trend-val{font-weight:800;font-variant-numeric:tabular-nums}
.trend-badge{font-size:10px;font-weight:800;padding:2px 7px;border-radius:5px}
.bull{background:var(--gbg);color:var(--gt)}.bear{background:var(--rbg);color:var(--rt)}.neut{background:var(--abg);color:var(--at)}

/* ORDER TICKET */
.ot{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:12px}
.ot-hdr{background:var(--bg3);padding:10px 15px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.ot-hdr-t{font-size:13px;font-weight:800}
.ot-sym{font-size:12px;font-weight:800;color:var(--gt);background:var(--gbg);padding:3px 10px;border-radius:6px}
.ot-body{padding:14px 15px}
.og{display:grid;gap:10px;margin-bottom:12px}
.g3{grid-template-columns:1fr 1fr 1fr}.g2{grid-template-columns:1fr 1fr}
.ot-f{display:flex;flex-direction:column;gap:5px}
.ot-lbl{font-size:10px;font-weight:800;color:var(--text3);text-transform:uppercase;letter-spacing:.06em}
.ot-sel,.ot-in{background:var(--bg4);color:var(--text);border:1px solid var(--border2);border-radius:var(--rs);padding:10px 11px;font-size:14px;font-weight:600;width:100%;outline:none;font-family:inherit;-moz-appearance:textfield}
.ot-sel:focus,.ot-in:focus{border-color:var(--gt)}
.ot-in::-webkit-outer-spin-button,.ot-in::-webkit-inner-spin-button{-webkit-appearance:none}
.qt-cell{background:var(--bg3);border:1px solid var(--border);border-radius:var(--rs);padding:9px 11px;min-height:44px;display:flex;flex-direction:column;justify-content:center;transition:background .3s}
.qt-val{font-size:15px;font-weight:800;font-variant-numeric:tabular-nums}
.qt-sz{font-size:10px;color:var(--text3);margin-top:1px}
.qt-lbl{font-size:10px;font-weight:800;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:5px}
@keyframes fg{0%{background:rgba(34,201,138,.4)}100%{background:var(--bg3)}}
@keyframes fr{0%{background:rgba(255,95,94,.4)}100%{background:var(--bg3)}}
.flash-g{animation:fg .5s forwards}.flash-r{animation:fr .5s forwards}
.ot-div{border-top:1px solid var(--border);margin:12px 0}
.place-btn{width:100%;padding:15px;border:none;border-radius:var(--r);font-size:15px;font-weight:800;cursor:pointer;transition:opacity .15s}
.place-btn:active{opacity:.8}.place-btn:disabled{background:var(--bg4);color:var(--text3);cursor:not-allowed}
.btn-sell{background:var(--red);color:#fff}.btn-buy{background:var(--blue);color:#fff}
.est-row{text-align:center;font-size:12px;color:var(--text3);margin-bottom:10px;font-weight:600}
.est-row span{color:var(--text2);font-weight:800}
.sug-banner{background:var(--gbg);border:1px solid rgba(34,201,138,.3);border-radius:var(--r);padding:12px 14px;margin-bottom:12px}
.sug-lbl{font-size:10px;font-weight:800;color:var(--gt);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px}
.sug-body{font-size:12px;color:var(--text2);line-height:1.5;margin-bottom:8px}
.apply-btn{background:var(--green);color:#000;border:none;border-radius:var(--rs);padding:9px 16px;font-size:12px;font-weight:800;cursor:pointer;width:100%}

/* POSITIONS TABLE */
.pos-table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin-bottom:12px}
.pos-table{width:100%;border-collapse:collapse;font-size:11px;min-width:700px}
.pos-table th{background:var(--bg3);color:var(--text3);font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;padding:8px 10px;border-bottom:1px solid var(--border);white-space:nowrap;text-align:right}
.pos-table th:first-child{text-align:left}
.pos-table td{padding:10px 10px;border-bottom:1px solid var(--border);color:var(--text2);text-align:right;white-space:nowrap;vertical-align:middle}
.pos-table td:first-child{text-align:left}
.pos-table tr:last-child td{border-bottom:none}
.pos-table .sym-cell{font-weight:800;color:var(--bt);font-size:12px}
.pos-table .sym-sub{font-size:10px;color:var(--text3);font-weight:500;margin-top:1px}
.pos-table .act-btn{background:var(--green);color:#000;border:none;border-radius:5px;padding:4px 10px;font-size:10px;font-weight:800;cursor:pointer;white-space:nowrap}
.pos-table .btc-btn{background:var(--red);color:#fff;border:none;border-radius:5px;padding:4px 10px;font-size:10px;font-weight:800;cursor:pointer}
.pos-footer{background:var(--bg3);font-weight:800}
.pos-footer td{color:var(--text);padding:10px}

/* GAINS TABLE */
.gl-filters{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:12px}
.gl-sel,.gl-date{background:var(--bg3);color:var(--text);border:1px solid var(--border2);border-radius:var(--rs);padding:9px 10px;font-size:12px;font-weight:600;width:100%;outline:none;font-family:inherit}
.gl-sel:focus,.gl-date:focus{border-color:var(--gt)}
.gl-summary{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-bottom:14px}
.gl-met{background:var(--bg3);border-radius:var(--rs);padding:10px;text-align:center}
.gl-met-lbl{font-size:9px;color:var(--text3);font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;line-height:1.3}
.gl-met-val{font-size:14px;font-weight:800;font-variant-numeric:tabular-nums}
.gl-table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}
.gl-table{width:100%;border-collapse:collapse;font-size:11px;min-width:900px}
.gl-table th{background:var(--bg3);color:var(--text3);font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;padding:8px 8px;border-bottom:1px solid var(--border);white-space:nowrap;text-align:right;cursor:pointer}
.gl-table th:first-child,.gl-table th:nth-child(2){text-align:left}
.gl-table th:hover{color:var(--text)}
.gl-table td{padding:8px 8px;border-bottom:1px solid var(--border);color:var(--text2);text-align:right;white-space:nowrap;vertical-align:top}
.gl-table td:first-child,.gl-table td:nth-child(2){text-align:left}
.gl-sym{font-weight:800;color:var(--bt);font-size:12px}
.gl-sub{font-size:10px;color:var(--text3);margin-top:1px;font-weight:500}
.gl-act{font-size:11px;color:var(--gt);font-weight:700}
.gl-group-row{background:var(--bg3)}
.gl-group-row td{font-weight:700;color:var(--text);padding:6px 8px}
.expand-btn{background:none;border:none;color:var(--text3);cursor:pointer;font-size:12px;padding:0 4px}

/* RULES */
.rule-block{border-left:2.5px solid var(--border2);padding:10px 12px;margin-bottom:9px;border-radius:0 var(--rs) var(--rs) 0;background:var(--bg3)}
.rule-g{border-left-color:var(--green)}.rule-a{border-left-color:var(--amber)}.rule-r{border-left-color:var(--red)}.rule-b{border-left-color:var(--blue)}
.rule-title-row{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:5px}
.rule-title-text{font-size:13px;font-weight:700;color:var(--text);flex:1}
.edit-btn{background:none;border:1px solid var(--border2);border-radius:5px;padding:3px 9px;font-size:10px;color:var(--text3);cursor:pointer;font-weight:700}
.rule-body{font-size:12px;color:var(--text2);line-height:1.55}
.rule-edit-area{display:none;margin-top:8px}.rule-edit-area.open{display:block}
.rule-ta{width:100%;background:var(--bg4);border:1px solid var(--border2);border-radius:var(--rs);padding:8px 10px;font-size:12px;color:var(--text);line-height:1.55;resize:vertical;min-height:60px;font-family:inherit;outline:none}
.rule-ta:focus{border-color:var(--gt)}
.rule-edit-btns{display:flex;gap:6px;margin-top:6px;flex-wrap:wrap}
.btn-sr{background:var(--green);color:#000;border:none;border-radius:5px;padding:6px 12px;font-size:11px;font-weight:800;cursor:pointer}
.btn-cr{background:var(--bg4);color:var(--text2);border:1px solid var(--border2);border-radius:5px;padding:6px 12px;font-size:11px;cursor:pointer;font-weight:700}
.btn-rr{background:none;color:var(--rt);border:none;font-size:11px;cursor:pointer;font-weight:700}

/* CHART */
.chart-wrap{position:relative;width:100%;height:200px;margin-top:8px}

/* CONFIRM */
#conf-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:200;align-items:flex-end}
#conf-overlay.open{display:flex}
#conf-modal{background:var(--bg2);border-radius:var(--r) var(--r) 0 0;padding:20px 18px 36px;width:100%}
#conf-modal h3{font-size:16px;font-weight:800;margin-bottom:4px}
#conf-modal p{font-size:13px;color:var(--text2);margin-bottom:16px;line-height:1.5}
.conf-detail{background:var(--bg3);border-radius:var(--rs);padding:12px 14px;margin-bottom:16px}
.conf-btns{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.btn-cc{background:var(--bg4);color:var(--text2);border:none;border-radius:var(--rs);padding:14px;font-size:14px;font-weight:700;cursor:pointer}
.btn-cf{border:none;border-radius:var(--rs);padding:14px;font-size:14px;font-weight:800;cursor:pointer}
.btn-cf-sell{background:var(--red);color:#fff}.btn-cf-buy{background:var(--blue);color:#fff}

/* TOAST */
#toast{position:fixed;bottom:70px;left:50%;transform:translateX(-50%);background:var(--bg3);color:var(--text);border:1px solid var(--border2);border-radius:var(--r);padding:10px 18px;font-size:13px;font-weight:700;z-index:300;opacity:0;transition:opacity .25s;pointer-events:none;white-space:nowrap;box-shadow:0 4px 24px rgba(0,0,0,.5)}
#toast.show{opacity:1}
/* INSTALL */
#ibanner{display:none;position:fixed;bottom:0;left:0;right:0;background:var(--bg2);border-top:1px solid var(--border);padding:12px 16px;z-index:50;align-items:center;gap:10px}
#ibanner.show{display:flex}
#ibanner p{flex:1;font-size:12px;color:var(--text2)}
#ibanner strong{color:var(--text);display:block;font-size:13px}
#ibtn{background:var(--green);color:#000;border:none;border-radius:var(--rs);padding:9px 14px;font-size:12px;font-weight:800;cursor:pointer}
#idismiss{background:none;border:none;color:var(--text3);font-size:24px;cursor:pointer}
</style>
</head>
<body>
<div id="app">

<!-- HEADER -->
<div id="hdr">
  <div id="hdr-row">
    <div>
      <h1>QQQ Put Algo</h1>
      <div class="sub">87.6% win rate · $67,384 realized</div>
      <div id="mkt-row"><div class="dot dc" id="mkt-dot"></div><span id="mkt-lbl">Checking...</span></div>
    </div>
    <div id="price-block">
      <div id="qqq-price">—</div>
      <div id="price-meta">
        <div id="price-chg" style="color:var(--text3)">—</div>
        <div id="ba-row">
          <div class="ba"><span class="ba-l">B </span><span id="hdr-bid">—</span></div>
          <div class="ba"><span class="ba-l">A </span><span id="hdr-ask">—</span></div>
        </div>
        <div id="upd-lbl">loading...</div>
      </div>
    </div>
  </div>
</div>

<!-- TABS -->
<div id="tabs">
  <button class="tb active" onclick="showTab('signal',this)">Signal</button>
  <button class="tb" onclick="showTab('order',this)">Order</button>
  <button class="tb" onclick="showTab('positions',this)">Positions</button>
  <button class="tb" onclick="showTab('gains',this)">Gains &amp; Losses</button>
  <button class="tb" onclick="showTab('entry',this)">Entry Rules</button>
  <button class="tb" onclick="showTab('exit',this)">Exit &amp; Roll</button>
  <button class="tb" onclick="showTab('stats',this)">Stats</button>
</div>

<div id="content">

<!-- ══ SIGNAL TAB ══ -->
<div id="panel-signal" class="panel active">
  <div id="pos-alert-wrap"></div>

  <!-- Main signal -->
  <div id="sig-card" class="sig sig-g">
    <div class="sig-lbl">
      <span id="sig-lbl-text">Analyzing...</span>
      <span class="cd-badge" id="sig-cd">5:00</span>
    </div>
    <div class="sig-title" id="sig-title">Fetching live data...</div>
    <div class="sig-desc" id="sig-desc">Loading QQQ price and market conditions</div>
    <div class="sig-rec" id="sig-rec" style="display:none">
      <div class="sig-rec-lbl">Algorithm says (201 trades analyzed)</div>
      <div class="sig-rec-body" id="sig-rec-body"></div>
    </div>
  </div>

  <!-- Live Market Data (reordered per spec) -->
  <p class="stitle">Live market data <span style="font-size:9px;text-transform:none;letter-spacing:0;font-weight:400">(auto · override below)</span></p>
  <div class="card">
    <!-- 1. Pre-market QQQ -->
